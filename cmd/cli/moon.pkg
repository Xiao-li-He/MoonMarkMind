import {
  "moonbitlang/core/argparse",
  "moonbitlang/core/env",
  "moonbitlang/x/sys",
  "mizchi/js/core",
  "mizchi/js/node",
  "mizchi/js/node/child_process",
  "mizchi/js/node/fs" @node_fs,
  "mizchi/js/node/http",
  "mizchi/js/node/os",
  "mizchi/js/node/path",
  "mizchi/js/web/http" @web_http,
