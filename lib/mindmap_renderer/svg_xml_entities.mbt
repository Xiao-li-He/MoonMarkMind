///|
fn normalize_svg_xml_entities(value : String) -> String {
  let mut out = value
  out = out.replace_all(old="&alpha;", new="&#945;")
  out = out.replace_all(old="&beta;", new="&#946;")
  out = out.replace_all(old="&gamma;", new="&#947;")
  out = out.replace_all(old="&delta;", new="&#948;")
  out = out.replace_all(old="&epsilon;", new="&#949;")
  out = out.replace_all(old="&theta;", new="&#952;")
  out = out.replace_all(old="&lambda;", new="&#955;")
  out = out.replace_all(old="&mu;", new="&#956;")
  out = out.replace_all(old="&pi;", new="&#960;")
  out = out.replace_all(old="&rho;", new="&#961;")
  out = out.replace_all(old="&sigma;", new="&#963;")
  out = out.replace_all(old="&tau;", new="&#964;")
  out = out.replace_all(old="&phi;", new="&#966;")
  out = out.replace_all(old="&omega;", new="&#969;")
  out = out.replace_all(old="&Gamma;", new="&#915;")
  out = out.replace_all(old="&Delta;", new="&#916;")
  out = out.replace_all(old="&Theta;", new="&#920;")
  out = out.replace_all(old="&Lambda;", new="&#923;")
  out = out.replace_all(old="&Pi;", new="&#928;")
  out = out.replace_all(old="&Sigma;", new="&#931;")
  out = out.replace_all(old="&Phi;", new="&#934;")
  out = out.replace_all(old="&Omega;", new="&#937;")
  out = out.replace_all(old="&times;", new="&#215;")
  out = out.replace_all(old="&middot;", new="&#183;")
  out = out.replace_all(old="&plusmn;", new="&#177;")
  out = out.replace_all(old="&le;", new="&#8804;")
  out = out.replace_all(old="&ge;", new="&#8805;")
  out = out.replace_all(old="&ne;", new="&#8800;")
  out = out.replace_all(old="&asymp;", new="&#8781;")
  out = out.replace_all(old="&infin;", new="&#8734;")
  out = out.replace_all(old="&sum;", new="&#8721;")
  out = out.replace_all(old="&prod;", new="&#8719;")
  out = out.replace_all(old="&int;", new="&#8747;")
  out = out.replace_all(old="&rarr;", new="&#8594;")
  out = out.replace_all(old="&larr;", new="&#8592;")
  out = out.replace_all(old="&rArr;", new="&#8658;")
  out = out.replace_all(old="&lArr;", new="&#8656;")
  out = out.replace_all(old="&harr;", new="&#8596;")
  out = out.replace_all(old="&isin;", new="&#8712;")
  out = out.replace_all(old="&notin;", new="&#8713;")
  out = out.replace_all(old="&sub;", new="&#8834;")
  out = out.replace_all(old="&sube;", new="&#8838;")
  out = out.replace_all(old="&sup;", new="&#8835;")
  out = out.replace_all(old="&supe;", new="&#8839;")
  out = out.replace_all(old="&cup;", new="&#8746;")
  out = out.replace_all(old="&cap;", new="&#8745;")
  out = out.replace_all(old="&empty;", new="&#8709;")
  out = out.replace_all(old="&forall;", new="&#8704;")
  out = out.replace_all(old="&exist;", new="&#8707;")
  out = out.replace_all(old="&nabla;", new="&#8711;")
  out = out.replace_all(old="&part;", new="&#8706;")
  out = out.replace_all(old="&hellip;", new="&#8230;")
  out.replace_all(old="&nbsp;", new="&#160;")
}
