name = "Xiao-li-He/MoonMarkMind"

version = "0.1.0"

source = "."

import {
  "mizchi/js@0.12.1",
  "mizchi/js_browser@0.12.1",
  "moonbitlang/async@0.20.1",
  "moonbitlang/x@0.4.46",
  "mizchi/x@0.5.1",
}

readme = "README.mbt.md"

repository = "https://github.com/Xiao-li-He/MoonMarkMind"

license = "Apache-2.0"

keywords = [ "markdown", "mindmap", "outline", "svg", "html", "cli" ]

description = "Markdown mind-map toolkit and browser application built with MoonBit"

preferred_target = "js"
