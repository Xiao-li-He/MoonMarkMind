import {
  "mizchi/js/core" @core,
  "mizchi/js/browser/dom" @dom,
  "mizchi/js/browser/canvas" @canvas,
  "mizchi/js/browser/file" @file,
  "mizchi/js/web/event" @event,
  "moonbitlang/core/math" @math,
  "moonbitlang/core/ref" @ref,
  "moonbitlang/core/strconv" @strconv,
  "mizchi/js/builtins/global" @global,
}

options(
  "supported-targets": "js",
  targets: {
    "heading_parser.mbt": [ "js" ],
    "latex_math_render.mbt": [ "js" ],
    "markdown_render.mbt": [ "js" ],
    "outline_model.mbt": [ "js" ],
    "outline_model_test.mbt": [ "js" ],
    "outline_tree.mbt": [ "js" ],
    "sample_data.mbt": [ "js" ],
    "web_dom.mbt": [ "js" ],
    "web_frontend.mbt": [ "js" ],
    "web_layout.mbt": [ "js" ],
    "web_mindmap_bindings.mbt": [ "js" ],
  },
)
