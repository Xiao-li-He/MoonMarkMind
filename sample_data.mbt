///|
fn rules_test_markdown() -> String {
  (
    #|# 根节点
    #|
    #|这是根节点的说明文本，用来测试标题后的正文是否会被保留。
    #|
    #|## 一层分支 A
    #|
    #|这一节用来测试标题下面直接接列表、正文和同级顺序。
    #|
    #|- 标题下面直接接列表
    #|- 列表项可以作为子节点
    #|- 同级兄弟节点的顺序
    #|
    #|### 二层分支 A1
    #|
    #|#### 三层分支 A1-1
    #|
    #|##### 四层分支 A1-1-1
    #|
    #|###### 五层分支 A1-1-1-1
    #|
    #|超过 `######` 以后继续使用列表表示更深层级。
    #|
    #|- 六层分支 A1-1-1-1-1
    #|  - 七层分支 A1-1-1-1-1-1
    #|    - 八层分支 A1-1-1-1-1-1-1
    #|
    #|### 二层分支 A2
    #|
    #|- 同级列表 A2-1
    #|- 同级列表 A2-2
    #|  - 子列表 A2-2-1
    #|    - 子列表 A2-2-1-1
    #|
    #|## 一层分支 B
    #|
    #|1. 有序列表 B1
    #|2. 有序列表 B2
    #|   1. 嵌套有序 B2-1
    #|   2. 嵌套有序 B2-2
    #|
    #|## 一层分支 C
    #|
    #|- [链接节点](https://example.com)
    #|- **粗体节点**
    #|- *斜体节点*
    #|- `行内代码节点`
    #|- ~~删除线节点~~
    #|
    #|### 二层分支 C1
    #|
    #|这一段用来测试正文和列表混排时的区分。
    #|
    #|- 这是正文里的条目
    #|- 这也是正文里的条目
    #|
    #|#### 三层分支 C1-1
    #|
    #|```ts
    #|const title = "code block"
    #|function add(a: number, b: number) {
    #|  return a + b
    #|}
    #|```
    #|
    #|> 这是引用块文本
    #|> 主要用于测试它会被保留为当前节点正文。
    #|
    #|### 二层分支 C2
    #|
    #|- [ ] 待办事项
    #|- [x] 已完成事项
    #|
    #|## 一层分支 D
    #|
    #|![图片测试](https://example.com/image.png)
    #|
    #|### 二层分支 D1
    #|
    #|- 兄弟节点 D1-1
    #|- 兄弟节点 D1-2
    #|  - 子节点 D1-2-1
    #|
    #|### 二层分支 D2
    #|
    #|这一段正文用来测试：
    #|
    #|1. 节点内容是否可以在标题之后保留段落
    #|2. 段落后再接列表时，父子关系是否正确
    #|
    #|- 列表节点 D2-1
    #|- 列表节点 D2-2
    #|
    #|## 一层分支 E
    #|
    #|### 二层分支 E1
    #|
    #|#### 三层分支 E1-1
    #|
    #|##### 四层分支 E1-1-1
    #|
    #|###### 五层分支 E1-1-1-1
    #|
    #|- 第七层测试 E1-1-1-1-1
    #|  - 第八层测试 E1-1-1-1-1-1
    #|    - 第九层测试 E1-1-1-1-1-1-1
