///|
pub fn sample_markdown() -> String {
  "# MoonMarkMind Demo\n## Parser\n### Heading extraction\n### Level mapping\n## Renderer\n### ASCII mindmap\n### Round-trip preview"
}

///|
fn rules_test_markdown() -> String {
  let lines = [
    "# 根节点", "", "这是根节点的说明文本，用来测试标题后的正文是否会被保留。",
    "", "## 一级分支 A", "", "这一段用于测试：", "", "- 标题下直接接列表",
    "- 列表项作为子节点", "- 同级兄弟节点的顺序", "", "### 二级分支 A1",
    "", "#### 三级分支 A1-1", "", "##### 四级分支 A1-1-1", "", "###### 五级分支 A1-1-1-1",
    "", "这里已经到达 `######`，下面继续使用列表来测试更深层级。",
    "", "- 六级分支 A1-1-1-1-1", "  - 七级分支 A1-1-1-1-1-1", "    - 八级分支 A1-1-1-1-1-1-1",
    "", "### 二级分支 A2", "", "- 同级列表 A2-1", "- 同级列表 A2-2",
    "  - 子列表 A2-2-1", "    - 子列表 A2-2-1-1", "", "## 一级分支 B",
    "", "1. 有序列表 B1", "2. 有序列表 B2", "   1. 嵌套有序 B2-1", "   2. 嵌套有序 B2-2",
    "", "## 一级分支 C", "", "- [链接节点](https://example.com)", "- **粗体节点**",
    "- *斜体节点*", "- `行内代码节点`", "- ~~删除线节点~~", "", "### 二级分支 C1",
    "", "这里测试正文列表和结构列表的区分：", "", "- 这是一条正文里的条目",
    "- 这也是正文里的条目", "", "#### 三级分支 C1-1", "", "```ts", "const title = \"code block\";",
    "function add(a: number, b: number) {", "  return a + b;", "}", "```", "", "> 这是引用块文本。",
    "> 主要测试它是否会被当成当前节点正文保留。", "", "### 二级分支 C2",
    "", "- [ ] 待办事项", "- [x] 已完成事项", "", "## 一级分支 D", "",
    "![图片测试](https://example.com/image.png)", "", "### 二级分支 D1",
    "", "- 兄弟节点 D1-1", "- 兄弟节点 D1-2", "  - 子节点 D1-2-1", "",
    "### 二级分支 D2", "", "这一段文字用来测试：", "", "1. 节点内容是否可以在标题之后保留段落",
    "2. 段落后再接列表时，父子关系是否正确", "", "- 列表节点 D2-1",
    "- 列表节点 D2-2", "", "## 一级分支 E", "", "### 二级分支 E1", "",
    "#### 三级分支 E1-1", "", "##### 四级分支 E1-1-1", "", "###### 五级分支 E1-1-1-1",
    "", "- 第七层测试 E1-1-1-1-1", "  - 第八层测试 E1-1-1-1-1-1", "    - 第九层测试 E1-1-1-1-1-1-1",
    "", "### 二级分支 E2", "", "- E2-1", "  - E2-1-1", "    - E2-1-1-1", "- E2-2",
    "", "## 一级分支 F", "", "这一节专门测试多个顶层标题之间是否互为兄弟节点。",
    "", "### 二级分支 F1", "", "- F1-1", "- F1-2", "", "## 一级分支 G", "",
    "- G-1", "- G-2", "", "### 二级分支 G1", "", "#### 三级分支 G1-1", "",
    "这里再放一段正文。", "", "- G1-1-列表", "  - G1-1-子列表",
  ]
  lines.join("\n")
}
